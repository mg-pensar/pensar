{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "cmake-configure",
            "type": "shell",
            "command": "cmake -S ${workspaceFolder} -B ${workspaceFolder}/build",
            "windows": {
                "command": "cmake -S ${workspaceFolder} -B ${workspaceFolder}/build -DCMAKE_TOOLCHAIN_FILE=${workspaceFolder}/conan_toolchain.cmake"
            },
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": {
                "base": "$gcc",
                "owner": "cmake"
            }
        },
        {
            "label": "build-tests",
            "type": "shell",
            "command": "cmake --build ${workspaceFolder}/build --target pensar_tests",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "windows": {
                "problemMatcher": [
                    "$msCompile"
                ]
            },
            "group": {
                "kind": "build",
                "isDefault": true
            }
        },
        {
            "label": "run-tests",
            "type": "shell",
            "command": "cd ${workspaceFolder}/build && ctest --output-on-failure -j$(nproc)",
            "windows": {
                "command": "cd ${workspaceFolder}/build ; ctest --output-on-failure -j $env:NUMBER_OF_PROCESSORS"
            },
            "osx": {
                "command": "cd ${workspaceFolder}/build && ctest --output-on-failure -j$(sysctl -n hw.logicalcpu)"
            },
            "problemMatcher": [],
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "dependsOn": [
                "build-tests"
            ]
        },
        {
            "label": "build-contact-tests",
            "type": "shell",
            "command": "cmake --build ${workspaceFolder}/build --target contact_tests",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "windows": {
                "problemMatcher": [
                    "$msCompile"
                ]
            },
            "group": "build"
        },
        {
            "label": "run-contact-tests",
            "type": "shell",
            "command": "${workspaceFolder}/build/contact_tests --colour-mode ansi",
            "windows": {
                "command": "${workspaceFolder}\\build\\contact_tests.exe --colour-mode ansi"
            },
            "problemMatcher": [],
            "group": "test",
            "dependsOn": [
                "build-contact-tests"
            ]
        }
    ]
}
