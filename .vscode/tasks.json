{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "cmake-configure",
            "type": "shell",
            "command": "cmake -S ${workspaceFolder} -B ${workspaceFolder}/build",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "build-tests",
            "type": "shell",
            "command": "cmake --build ${workspaceFolder}/build --target pensar_tests",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "dependsOn": [
                "cmake-configure"
            ]
        },
        {
            "label": "run-tests",
            "type": "shell",
            "command": "cd ${workspaceFolder}/build && ctest --output-on-failure -j$(sysctl -n hw.logicalcpu)",
            "problemMatcher": [],
            "group": {
                "kind": "test",
                "isDefault": true
            },
            "dependsOn": [
                "build-tests"
            ]
        },
        {
            "label": "build-contact-tests",
            "type": "shell",
            "command": "cmake --build ${workspaceFolder}/build --target contact_tests",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": "build",
            "dependsOn": [
                "cmake-configure"
            ]
        },
        {
            "label": "run-contact-tests",
            "type": "shell",
            "command": "${workspaceFolder}/build/contact_tests --colour-mode ansi",
            "problemMatcher": [],
            "group": "test",
            "dependsOn": [
                "build-contact-tests"
            ]
        }
    ]
}
