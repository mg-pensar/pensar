{
    "C_Cpp.errorSquiggles": "enabled",
    "C_Cpp.default.cppStandard": "c++23",
    "C_Cpp.default.configurationProvider": "ms-vscode.cmake-tools",
    "cmake.buildDirectory": "${workspaceFolder}/build",
    "cmake.configureOnOpen": true,
    "cmake.defaultVariants": {},
    "cmake.launchBehavior": "reuseTerminal",
    "cmake.useCMakePresets": "always",
    "cmake.buildBeforeRun": true,

    // --- CMake Tools: default launch/build targets ---
    "cmake.defaultBuildTarget": "all",
    "cmake.defaultLaunchTarget": "pensar_tests",
    "cmake.buildArgs": ["--config", "Debug"],

    // --- C++ TestMate: discover Catch2 test executables ---
    "testMate.cpp.test.executables": "${workspaceFolder}/build/{pensar_tests,contact_tests}",
    "testMate.cpp.test.workingDirectory": "${workspaceFolder}",
    "rust-analyzer.workspace.discoverConfig": null
}