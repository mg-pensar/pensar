{
    "C_Cpp.errorSquiggles": "enabled",
    "C_Cpp.default.cppStandard": "c++23",
    "cmake.buildDirectory": "${workspaceFolder}/build",
    "cmake.configureOnOpen": true,
    "cmake.defaultVariants": {},
    "cmake.launchBehavior": "newTerminal",
    "cmake.debugConfig": {
        "type": "cppdbg",
        "request": "launch",
        "program": "${command:cmake.launchTargetPath}",
        "args": [],
        "cwd": "${workspaceFolder}",
        "MIMode": "lldb",
        "stopOnEntry": false
    },

    // --- CMake Tools: default launch target ---
    "cmake.defaultBuildTarget": "contact_tests",
    "cmake.defaultLaunchTarget": "contact_tests",

    // --- C++ TestMate: discover Catch2 test executables ---
    "testMate.cpp.test.executables": "${workspaceFolder}/build/{pensar_tests,contact_tests}",
    "testMate.cpp.test.workingDirectory": "${workspaceFolder}"
}